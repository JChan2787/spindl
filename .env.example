# Cloud LLM provider (DeepSeek)
DEEPSEEK_API_KEY=sk-your-key-here

# Cloud LLM router (OpenRouter) — access 200+ models with one key
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Cloud LLM provider (OpenAI) — optional
OPENAI_API_KEY=sk-your-key-here

# Cloud sentiment/search provider (xAI Grok) — optional
XAI_API_KEY=xai-your-key-here

# Twitch integration — register at https://dev.twitch.tv/console/apps
TWITCH_APP_ID=your-app-id-here
TWITCH_APP_SECRET=your-app-secret-here
