{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "SpindL Subtitles",
  "version": "0.1.0",
  "identifier": "com.spindl.subtitles",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:48121",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "subtitles",
        "title": "SpindL Subtitles",
        "width": 800,
        "height": 150,
        "x": 560,
        "y": 880,
        "alwaysOnTop": true,
        "decorations": false,
        "resizable": true,
        "skipTaskbar": true,
        "transparent": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' ws://127.0.0.1:* http://127.0.0.1:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
